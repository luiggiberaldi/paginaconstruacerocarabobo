# ─────────────────────────────────────────────────────────────────
# Listo POS Cotizaciones — Variables de entorno
# Copia este archivo como .env y completa con tus credenciales reales
# NUNCA subas el archivo .env al repositorio
# ─────────────────────────────────────────────────────────────────

# Supabase — Proyecto NUEVO e independiente (no el del POS original)
# Obtén estos valores en: supabase.com → tu proyecto → Settings → API
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─────────────────────────────────────────────────────────────────
# Worker API Origin (SOLO para deploy en Vercel)
# ─────────────────────────────────────────────────────────────────
# Cuando la app se despliega en Vercel, el frontend necesita saber
# dónde está el Cloudflare Worker para las rutas /api/*.
# Dejar vacío o no definir si se usa el proxy de vercel.json.
#
# IMPORTANTE: Usar la URL del Worker en workers.dev, NO camelai.app
# VITE_WORKER_ORIGIN=https://listo-pos-cotizaciones.luigistorelogistics.workers.dev
